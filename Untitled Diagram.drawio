<mxfile host="app.diagrams.net" pages="3">
  <diagram name="Page-1" id="LZ8da8ATIoqN17joIIyl">
    <mxGraphModel dx="936" dy="479" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle EMAP - FYP Management System\\nClean Data Flow / Architecture\n\nleft to right direction\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam defaultFontName Arial\nskinparam packageStyle rectangle\nskinparam ArrowColor #2563EB\nskinparam rectangle {\n  BackgroundColor #F8FAFC\n  BorderColor #334155\n  FontColor #0F172A\n  RoundCorner 12\n}\nskinparam database {\n  BackgroundColor #FEF3C7\n  BorderColor #B45309\n  FontColor #78350F\n}\nskinparam cloud {\n  BackgroundColor #DBEAFE\n  BorderColor #1D4ED8\n  FontColor #1E3A8A\n}\nskinparam actor {\n  BorderColor #334155\n  FontColor #0F172A\n}\n\nactor Admin\nactor Student\nactor Supervisor\nactor Coordinator\n\npackage \&quot;Presentation Layer\&quot; {\n  rectangle \&quot;Admin Dashboard\&quot; as AdminUI\n  rectangle \&quot;Student Dashboard\\n+ FYP Portal\&quot; as StudentUI\n  rectangle \&quot;Supervisor Dashboard\&quot; as SupervisorUI\n  rectangle \&quot;Coordinator Dashboard\&quot; as CoordinatorUI\n  rectangle \&quot;File Preview Pages\&quot; as PreviewUI\n}\n\npackage \&quot;Application Layer\&quot; {\n  rectangle \&quot;Authentication &amp; Authorization\&quot; as Auth\n  rectangle \&quot;Admin Controller\&quot; as AdminController\n  rectangle \&quot;Fyp Controller\&quot; as FypController\n  rectangle \&quot;Supervisor Controller\&quot; as SupervisorController\n  rectangle \&quot;Chapter Review Controller\&quot; as ChapterReviewController\n  rectangle \&quot;Coordinator Controller\&quot; as CoordinatorController\n  rectangle \&quot;Evaluation Controller\&quot; as EvalController\n  rectangle \&quot;File Preview Controller\&quot; as FilePreviewController\n  rectangle \&quot;Email Service\&quot; as EmailService\n}\n\npackage \&quot;Data Layer\&quot; {\n  database \&quot;EMAP Database\&quot; as DB\n  cloud \&quot;File Storage\\n(uploads)\&quot; as Storage\n  cloud \&quot;LMS / CMS\\nFuture Integration\&quot; as LMS\n}\n\nAdmin --&gt; AdminUI\nStudent --&gt; StudentUI\nSupervisor --&gt; SupervisorUI\nCoordinator --&gt; CoordinatorUI\nStudent --&gt; PreviewUI\nSupervisor --&gt; PreviewUI\nCoordinator --&gt; PreviewUI\n\nAdminUI --&gt; AdminController\nStudentUI --&gt; FypController\nSupervisorUI --&gt; SupervisorController\nSupervisorUI --&gt; ChapterReviewController\nCoordinatorUI --&gt; CoordinatorController\nCoordinatorUI --&gt; EvalController\nPreviewUI --&gt; FilePreviewController\n\nAdminController --&gt; Auth\nFypController --&gt; Auth\nSupervisorController --&gt; Auth\nChapterReviewController --&gt; Auth\nCoordinatorController --&gt; Auth\nEvalController --&gt; Auth\nFilePreviewController --&gt; Auth\n\nAdminController --&gt; DB\nFypController --&gt; DB\nSupervisorController --&gt; DB\nChapterReviewController --&gt; DB\nCoordinatorController --&gt; DB\nEvalController --&gt; DB\nFilePreviewController --&gt; DB\n\nFypController --&gt; Storage\nSupervisorController --&gt; Storage\nChapterReviewController --&gt; Storage\nCoordinatorController --&gt; Storage\nFilePreviewController --&gt; Storage\n\nCoordinatorController --&gt; EmailService\nEvalController --&gt; EmailService\nEmailService --&gt; Student\n\nDB --&gt; LMS\n\nnote bottom of DB\nStores:\n- Users\n- FYP Calls\n- Committees\n- Supervisors\n- Student Groups\n- Proposals\n- Defense Schedules\n- Chapters\n- Evaluations\n- Rubric Scores\nend note\n\nnote right of LMS\nIntegration-ready output:\n- completed group status\n- stage progression\n- final evaluation state\n- sync readiness\nend note\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;png&quot;&#xa;}" id="qQHPz-KjNDBUP5qoLjrB-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1">
            <mxGeometry height="958" width="1320" x="40" y="40" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="2DhAkrox8MwB2mb1m1iH" name="Page-2">
    <mxGraphModel dx="1084" dy="555" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle EMAP - FYP-1 Workflow (Start to Promotion)\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam defaultFontName Arial\nskinparam ArrowColor #2F5597\n\n|Admin|\nstart\n:Create FYP Call;\n:Add Batch / Department;\n:Activate Call;\n:Add Supervisors;\n:Assign Coordinators;\n\n|Student|\n:Login Dashboard;\n:Open FYP Portal;\n:Create Group;\n:Add Members;\n:Select Supervisor;\n\n|Supervisor|\n:Review Group Request;\nif (Approve?) then (Yes)\n  :Approve Group;\nelse (No)\n  :Reject Group;\n  |Student|\n  :Select Another Supervisor;\nendif\n\n|Student|\n:Submit Proposal;\n:Upload File;\n\n|Supervisor|\n:Review Proposal;\nif (Approved?) then (Yes)\n  :Approve for Defense;\nelse (No)\n  :Request Changes;\nendif\n\n|Student|\n:Revise Proposal;\n:Resubmit;\n\n|Supervisor|\n:Approve Proposal;\n\n|Coordinator|\n:Assign Defense Slot;\n:Schedule Date/Time;\n\n|Student|\n:View Schedule;\n:Attend Defense;\n\n|Coordinator|\n:Record Defense Outcome;\n\n:Open Chapter 1;\n\n|Student|\n:Upload Chapter 1;\n\n|Supervisor|\n:Review Chapter 1;\nif (Approved?) then (Yes)\n  :Approve;\nelse (No)\n  :Request Changes;\nendif\n\n|Student|\n:Revise Chapter;\n\n|Coordinator|\n:Finalize Chapter 1;\n\n:Open Chapter 2;\n\n|Student|\n:Upload Chapter 2;\n\n|Supervisor|\n:Review Chapter 2;\n\n|Coordinator|\n:Finalize Chapter 2;\n\n:Open Chapter 3;\n\n|Student|\n:Upload Chapter 3;\n\n|Supervisor|\n:Review Chapter 3;\n\n|Coordinator|\n:Finalize Chapter 3;\n\n:Create Mid Evaluation;\n:Schedule Mid;\n:Conduct Mid;\n\n:Create Final Evaluation;\n:Conduct Final;\n\nif (FYP-1 Complete?) then (Yes)\n  :Finalize FYP-1;\n  :Promote to FYP-2;\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;png&quot;&#xa;}" id="-Oiu6PSzPoUPTGwgFWt6-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1">
            <mxGeometry height="2888" width="876" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="KvYfjp6WRASiD1srkr23" name="Page-3">
    <mxGraphModel dx="1030" dy="527" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle EMAP - FYP-2 Workflow (Continuation to Completion)\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam defaultFontName Arial\nskinparam ArrowColor #2F5597\nskinparam activity {\n  BackgroundColor #F8FAFC\n  BorderColor #334155\n  FontColor #0F172A\n  DiamondBackgroundColor #E2E8F0\n  DiamondBorderColor #475569\n  StartColor #16A34A\n  EndColor #DC2626\n  BarColor #94A3B8\n}\n\n|Student|\nstart\n:Now in FYP-2 Stage;\n\n|Coordinator|\n:Open Chapter 4;\n\n|Student|\n:Upload Chapter 4;\n\n|Supervisor|\n:Review Chapter 4;\n\n|Coordinator|\n:Finalize Chapter 4;\n:Open Chapter 5;\n\n|Student|\n:Upload Chapter 5;\n\n|Supervisor|\n:Review Chapter 5;\n\n|Coordinator|\n:Finalize Chapter 5;\n:Open Chapter 6;\n\n|Student|\n:Upload Chapter 6;\n\n|Supervisor|\n:Review Chapter 6;\n\n|Coordinator|\n:Finalize Chapter 6;\n:Create Mid Evaluation;\n:Schedule Mid Evaluation;\n\n|Student|\n:View Mid Evaluation Schedule;\n\n|Coordinator|\n:Conduct Mid Evaluation;\n:Save Mid Evaluation Result;\n:Create Pre-Final Evaluation;\n\nif (Pre-Final Required?) then (Yes)\n  :Schedule Pre-Final Evaluation;\n  :Conduct Pre-Final Evaluation;\n  :Save Pre-Final Result;\nelse (No)\n  :Skip Pre-Final Evaluation;\nendif\n\n:Create Final Evaluation;\n:Schedule Final Evaluation;\n\n|Student|\n:View Final Evaluation Schedule;\n\n|Coordinator|\n:Conduct Final Evaluation;\n:Save Final Evaluation Result;\n\nif (All Requirements Complete?) then (Yes)\n  :Finalize FYP-2;\n  :Mark Project Completed;\n  :Ready for LMS / CMS Sync;\nelse (No)\n  :Keep Group in FYP-2 Pending State;\nendif\n\n|Student|\n:View FYP Completed Successfully;\n:View Final Results;\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;png&quot;&#xa;}" id="kxMwRoWW64S4AVyV0L3I-4">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1">
            <mxGeometry height="1963" width="800" x="20" y="170" as="geometry" />
          </mxCell>
        </UserObject>
