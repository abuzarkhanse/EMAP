@model IEnumerable<EMAP.Domain.Fyp.StudentGroup>

@{
    ViewData["Title"] = "Finalize FYP-1";
}

<div class="mb-4">
    <div class="text-uppercase text-muted fw-semibold small">Coordinator Panel</div>
    <h2 class="mb-1">Finalize FYP-1</h2>
    <p class="text-muted mb-0">
        Finalize completed FYP-1 groups and promote them to FYP-2.
    </p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Group</th>
                        <th>Program</th>
                        <th>Batch</th>
                        <th>Supervisor</th>
                        <th>Current Stage</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No FYP-1 groups available for finalization.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var group in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@group.TentativeProjectTitle</div>
                                    <div class="text-muted small">Group #@group.Id</div>
                                </td>
                                <td>@group.ProgramCode</td>
                                <td>@group.FypCall?.Batch</td>
                                <td>@group.Supervisor?.Name</td>
                                <td>
                                    <span class="badge bg-secondary">@group.CurrentStage</span>
                                </td>
                                <td class="text-end">
                                    <form asp-action="FinalizeFyp1" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="groupId" value="@group.Id" />
                                        <button type="submit" class="btn btn-success btn-sm"
                                                onclick="return confirm('Finalize FYP-1 and move this group to FYP-2?');">
                                            Finalize FYP-1
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
