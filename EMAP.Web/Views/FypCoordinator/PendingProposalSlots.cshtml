@model IEnumerable<EMAP.Domain.Fyp.ProposalSubmission>

@{
    ViewData["Title"] = "Pending Proposal Slot Assignment";
}

<h2>Pending Proposal Slot Assignment</h2>
<p><strong>Committee:</strong> @ViewBag.CommitteeName</p>

<form asp-action="BulkAssignSlots" method="get">
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Select</th>
                <th>Proposal Id</th>
                <th>Title</th>
                <th>Batch</th>
                <th>Program</th>
                <th>Supervisor</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox" name="proposalIds" value="@item.Id" />
                    </td>
                    <td>@item.Id</td>
                    <td>@item.Title</td>
                    <td>@item.Group?.FypCall?.Batch</td>
                    <td>@item.Group?.ProgramCode</td>
                    <td>@item.Group?.Supervisor?.Name</td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">Assign Slots to Selected</button>
</form>
