@{
    ViewData["Title"] = "FYP Coordinator Dashboard";
}

<div class="coord-page container-fluid px-0">
    <div class="coord-header mb-4">
        <div>
            <div class="coord-kicker">School of Computing Sciences</div>
            <h1 class="coord-title">FYP Coordinator Dashboard</h1>
            <p class="coord-subtitle">
                Manage proposal scheduling, evaluation setup, rubric-based assessment, chapter workflow, and result publication.
            </p>
        </div>

        <div class="coord-user-chip">
            <span class="coord-user-label">Signed in as</span>
            <strong>@User.Identity?.Name</strong>
        </div>
    </div>

    <div class="coord-grid">
        <!-- Proposal Slot Allocation -->
        <section class="coord-card">
            <div class="coord-card-icon">📅</div>
            <div class="coord-card-body">
                <h3>Proposal Slot Allocation</h3>
                <p>
                    Assign proposal defense slots to approved groups using bulk or single allocation.
                </p>
            </div>
            <div class="coord-actions">
                <a asp-controller="FypCoordinator" asp-action="PendingProposalSlots" class="btn btn-primary">
                    Bulk Allocation
                </a>
                <a asp-controller="FypCoordinator" asp-action="Index" class="btn btn-outline-secondary">
                    Single Allocation
                </a>
            </div>
        </section>

        <!-- Proposal Defense Reviews -->
        <section class="coord-card">
            <div class="coord-card-icon">🛡️</div>
            <div class="coord-card-body">
                <h3>Proposal Defense Reviews</h3>
                <p>
                    Review proposal defense sessions, comments, outcomes, and committee observations.
                </p>
            </div>
            <div class="coord-actions">
                <a asp-controller="DefenseCommittee" asp-action="Index" class="btn btn-outline-primary">
                    Open Reviews
                </a>
            </div>
        </section>

        <!-- Unified Evaluation Management -->
        <section class="coord-card coord-card-highlight">
            <div class="coord-card-icon">🎓</div>
            <div class="coord-card-body">
                <h3>Evaluation Management</h3>
                <p>
                    Create, conduct, complete, and publish Mid, Pre-Final, and Final evaluations using rubric-based assessment.
                </p>

                <div class="coord-badges">
                    <span class="coord-badge">Mid / Pre-Final / Final</span>
                    <span class="coord-badge">Per Member Rubric</span>
                    <span class="coord-badge">Publish Later</span>
                </div>
            </div>
            <div class="coord-actions">
                <a asp-controller="FypMidEvaluation" asp-action="Index" class="btn btn-primary">
                    Manage Evaluations
                </a>
                <a asp-controller="FypMidEvaluation" asp-action="MyAssigned" class="btn btn-outline-primary">
                    Conduct Evaluations
                </a>
            </div>
        </section>

        <!-- Chapters -->
        <section class="coord-card">
            <div class="coord-card-icon">📘</div>
            <div class="coord-card-body">
                <h3>Chapter Workflow</h3>
                <p>
                    Open chapter windows, manage deadlines, and continue the phased FYP document workflow.
                </p>
            </div>
            <div class="coord-actions">
                <a asp-controller="FypCoordinator" asp-action="Chapters" class="btn btn-outline-primary">
                    Manage Chapters
                </a>
            </div>
        </section>

        <!-- Chapter Approvals -->
        <section class="coord-card">
            <div class="coord-card-icon">✅</div>
            <div class="coord-card-body">
                <h3>Chapter Approvals</h3>
                <p>
                    Review chapter submissions approved by supervisors and move them through coordinator validation.
                </p>
            </div>
            <div class="coord-actions">
                <a asp-controller="FypCoordinator" asp-action="ChapterApprovals" class="btn btn-outline-primary">
                    Review Approvals
                </a>
            </div>
        </section>

        <!-- Finalizing FYP-1 -->
        <section class="coord-card">
            <div class="coord-card-icon">🚀</div>
            <div class="coord-card-body">
                <h3>FYP-1 Finalization</h3>
                <p>
                    Finalize completed FYP-1 groups and promote them to FYP-2 for the next phase of the project.
                </p>
            </div>
            <div class="coord-actions">
                <a asp-controller="FypCoordinator" asp-action="FinalizeFyp1Groups" class="btn btn-primary">
                    Finalize FYP-1
                </a>
            </div>
        </section>
    </div>
</div>
