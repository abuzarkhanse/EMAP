@{
    ViewData["Title"] = "FYP Coordinator Dashboard";
}

<div class="container py-4 coordinator-dashboard">

    <!-- ===== HEADER ===== -->
    <div class="dashboard-hero mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1 class="dashboard-title mb-2">FYP Coordinator Dashboard</h1>
                <p class="dashboard-subtitle mb-0">
                    Manage proposal defense, chapter workflow, and evaluation activities from one place.
                </p>
            </div>

            <div class="user-badge">
                <i class="bi bi-person-circle me-2"></i>
                @User.Identity?.Name
            </div>
        </div>
    </div>

    <!-- ===== MAIN GRID ===== -->
    <div class="row g-4">

        <!-- Slot Allocation -->
        <div class="col-md-6 col-xl-4">
            <div class="card dashboard-panel h-100">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="panel-icon mb-3">
                        <i class="bi bi-calendar-check"></i>
                    </div>

                    <h4 class="panel-title mb-2">Slot Allocation</h4>
                    <p class="panel-text mb-4">
                        Assign proposal defense date and time slots for approved student groups.
                    </p>

                    <div class="mt-auto">
                        <a asp-controller="FypCoordinator"
                           asp-action="SlotAllocation"
                           class="btn btn-primary btn-dashboard-action">
                            Open Slot Allocation
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Defense Evaluations -->
        <div class="col-md-6 col-xl-4">
            <div class="card dashboard-panel h-100">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="panel-icon mb-3">
                        <i class="bi bi-shield-check"></i>
                    </div>

                    <h4 class="panel-title mb-2">Defense Evaluations</h4>
                    <p class="panel-text mb-4">
                        Record proposal defense attendance, committee feedback, and final decisions.
                    </p>

                    <div class="mt-auto">
                        <a asp-controller="DefenseCommittee"
                           asp-action="Index"
                           class="btn btn-success btn-dashboard-action">
                            Open Evaluations
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chapters -->
        <div class="col-md-6 col-xl-4">
            <div class="card dashboard-panel h-100">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="panel-icon mb-3">
                        <i class="bi bi-journal-text"></i>
                    </div>

                    <h4 class="panel-title mb-2">Chapters</h4>
                    <p class="panel-text mb-4">
                        Open chapter submission windows and manage the phased document workflow for students.
                    </p>

                    <div class="mt-auto">
                        <a asp-controller="FypCoordinator"
                           asp-action="Chapters"
                           class="btn btn-outline-primary btn-dashboard-action">
                            Manage Chapters
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chapter Approvals -->
        <div class="col-md-6 col-xl-4">
            <div class="card dashboard-panel h-100">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="panel-icon mb-3">
                        <i class="bi bi-journal-check"></i>
                    </div>

                    <h4 class="panel-title mb-2">Chapter Approvals</h4>
                    <p class="panel-text mb-3">
                        Review chapter submissions that have already been approved by supervisors.
                    </p>

                    <div class="metric-badge mb-4">
                        Pending: @ViewBag.PendingChapterApprovals
                    </div>

                    <div class="mt-auto">
                        <a asp-controller="FypCoordinator"
                           asp-action="ChapterApprovals"
                           class="btn btn-outline-primary btn-dashboard-action">
                            Review Chapters
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- FYP Evaluations -->
        <div class="col-md-6 col-xl-8">
            <div class="card dashboard-panel dashboard-panel-highlight h-100">
                <div class="card-body p-4 d-flex flex-column">
                    <div class="panel-icon mb-3">
                        <i class="bi bi-clipboard-check"></i>
                    </div>

                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-2">
                        <div>
                            <h4 class="panel-title mb-2">FYP Evaluations</h4>
                            <p class="panel-text mb-0">
                                Manage Mid, Pre-Final, and Final evaluations including activation,
                                scheduling, publishing, venue details, and student instructions.
                            </p>
                        </div>

                        <span class="section-badge">Unified Workflow</span>
                    </div>

                    <div class="feature-points mt-3 mb-4">
                        <span>Activate evaluation milestones</span>
                        <span>Schedule date, time, and venue</span>
                        <span>Publish instructions to students</span>
                    </div>

                    <div class="mt-auto">
                        <a asp-controller="FypEvaluation"
                           asp-action="Index"
                           class="btn btn-outline-primary btn-dashboard-action">
                            Manage Evaluations
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
