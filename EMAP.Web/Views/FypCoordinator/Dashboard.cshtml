@{
    ViewData["Title"] = "FYP Coordinator Dashboard";
}

<div class="container py-4 coordinator-dashboard-page">

    <!-- Header -->
    <div class="dashboard-topbar mb-4">
        <div>
            <h1 class="dashboard-heading mb-1">FYP Coordinator Dashboard</h1>
            <p class="dashboard-subheading mb-0">
                Manage proposal defense, chapter workflow, and evaluation operations.
            </p>
        </div>

        <div class="dashboard-user-pill">
            <i class="bi bi-person-circle me-2"></i>
            @User.Identity?.Name
        </div>
    </div>

    <!-- Main grid -->
    <div class="dashboard-grid">

        <!-- Slot Allocation -->
        <section class="admin-card">
            <div class="admin-card-icon">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div class="admin-card-body">
                <h3>Slot Allocation</h3>
                <p>Assign proposal defense date and time slots to approved student groups.</p>
            </div>
            <div class="admin-card-footer">
                <a asp-controller="FypCoordinator"
                   asp-action="SlotAllocation"
                   class="btn btn-sm btn-primary admin-action-btn">
                    Open
                </a>
            </div>
        </section>

        <!-- Defense Evaluations -->
        <section class="admin-card">
            <div class="admin-card-icon">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="admin-card-body">
                <h3>Defense Evaluations</h3>
                <p>Record defense attendance, committee feedback, and final proposal decisions.</p>
            </div>
            <div class="admin-card-footer">
                <a asp-controller="DefenseCommittee"
                   asp-action="Index"
                   class="btn btn-sm btn-success admin-action-btn">
                    Open
                </a>
            </div>
        </section>

        <!-- Chapters -->
        <section class="admin-card">
            <div class="admin-card-icon">
                <i class="bi bi-journal-text"></i>
            </div>
            <div class="admin-card-body">
                <h3>Chapters</h3>
                <p>Open submission windows and control phased chapter workflow for students.</p>
            </div>
            <div class="admin-card-footer">
                <a asp-controller="FypCoordinator"
                   asp-action="Chapters"
                   class="btn btn-sm btn-outline-primary admin-action-btn">
                    Manage
                </a>
            </div>
        </section>

        <!-- Chapter Approvals -->
        <section class="admin-card">
            <div class="admin-card-icon">
                <i class="bi bi-journal-check"></i>
            </div>
            <div class="admin-card-body">
                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <h3 class="mb-0">Chapter Approvals</h3>
                    <span class="dashboard-count-chip">
                        Pending: @ViewBag.PendingChapterApprovals
                    </span>
                </div>
                <p>Review chapter submissions already approved by supervisors.</p>
            </div>
            <div class="admin-card-footer">
                <a asp-controller="FypCoordinator"
                   asp-action="ChapterApprovals"
                   class="btn btn-sm btn-outline-primary admin-action-btn">
                    Review
                </a>
            </div>
        </section>

        <!-- FYP Evaluations -->
        <section class="admin-card admin-card-wide admin-card-highlight">
            <div class="admin-card-icon">
                <i class="bi bi-clipboard-check"></i>
            </div>
            <div class="admin-card-body">
                <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-2">
                    <h3 class="mb-0">FYP Evaluations</h3>
                    <span class="dashboard-status-pill">Unified Workflow</span>
                </div>

                <p>
                    Manage Mid, Pre-Final, and Final evaluations including activation,
                    scheduling, publication, venue details, and student instructions.
                </p>

                <div class="dashboard-feature-tags">
                    <span>Milestones</span>
                    <span>Scheduling</span>
                    <span>Venue & instructions</span>
                    <span>Student visibility</span>
                </div>
            </div>
            <div class="admin-card-footer">
                <a asp-controller="FypEvaluation"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-primary admin-action-btn">
                    Manage Evaluations
                </a>
            </div>
        </section>

    </div>
</div>