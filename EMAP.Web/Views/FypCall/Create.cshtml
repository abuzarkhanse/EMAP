@model EMAP.Domain.Fyp.FypCall

@{
    ViewData["Title"] = "Create FYP Call";
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}

<h1>Create FYP Call</h1>

<div class="row">
    <div class="col-md-10">
        <form asp-action="Create" method="post" id="fypCallForm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Batch" class="form-label"></label>
                <input asp-for="Batch" class="form-control" placeholder="e.g. F22" />
                <span asp-validation-for="Batch" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Session" class="form-label"></label>
                <select asp-for="Session" class="form-select">
                    <option value="">-- Select Session --</option>
                    <option value="Fall">Fall</option>
                    <option value="Spring">Spring</option>
                    <option value="Summer">Summer</option>
                </select>
                <span asp-validation-for="Session" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DepartmentId" class="form-label"></label>
                <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments">
                    <option value="">-- Select Department --</option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" value="FYP Call" readonly />
                <input type="hidden" asp-for="Title" value="FYP Call" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="AnnouncementDate" class="form-label"></label>
                    <input asp-for="AnnouncementDate" type="date" class="form-control" min="@today" id="announcementDate" />
                    <span asp-validation-for="AnnouncementDate" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="ProposalDeadline" class="form-label"></label>
                    <input asp-for="ProposalDeadline" type="date" class="form-control" min="@today" id="proposalDeadline" />
                    <span asp-validation-for="ProposalDeadline" class="text-danger"></span>
                </div>
            </div>

            <div class="form-check form-switch mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Active FYP Call</label>
            </div>

            <button type="submit" class="btn btn-primary">
                Save FYP Call
            </button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const announcementDate = document.getElementById("announcementDate");
            const proposalDeadline = document.getElementById("proposalDeadline");
            const form = document.getElementById("fypCallForm");

            function syncDeadlineMin() {
                if (announcementDate.value) {
                    proposalDeadline.min = announcementDate.value;

                    if (proposalDeadline.value && proposalDeadline.value <= announcementDate.value) {
                        proposalDeadline.value = "";
                    }
                }
            }

            announcementDate.addEventListener("change", syncDeadlineMin);

            form.addEventListener("submit", function (e) {
                const today = new Date();
                today.setHours(0, 0, 0, 0);

                const ann = announcementDate.value ? new Date(announcementDate.value) : null;
                const dead = proposalDeadline.value ? new Date(proposalDeadline.value) : null;

                if (!ann || !dead) {
                    return;
                }

                if (ann < today) {
                    e.preventDefault();
                    alert("Announcement date cannot be in the past.");
                    return;
                }

                if (dead <= ann) {
                    e.preventDefault();
                    alert("Proposal deadline must be after announcement date.");
                    return;
                }
            });

            syncDeadlineMin();
        });
    </script>
}