@model EMAP.Domain.Fyp.FypCall

@{
    ViewData["Title"] = "Delete FYP Call";
}

<h1>Delete FYP Call</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this FYP Call?
</div>

<div class="card p-3 mb-3">
    <dl class="row">
        <dt class="col-sm-3">Batch</dt>
        <dd class="col-sm-9">@Model.Batch</dd>

        <dt class="col-sm-3">Session</dt>
        <dd class="col-sm-9">@Model.Session</dd>

        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">Announcement Date</dt>
        <dd class="col-sm-9">@Model.AnnouncementDate.ToString("dd MMM yyyy")</dd>

        <dt class="col-sm-3">Proposal Deadline</dt>
        <dd class="col-sm-9">@Model.ProposalDeadline.ToString("dd MMM yyyy")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Inactive")</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>