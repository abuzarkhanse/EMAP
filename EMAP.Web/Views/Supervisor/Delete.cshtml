@model EMAP.Domain.Fyp.FypSupervisor

@{
    ViewData["Title"] = "Delete Supervisor";
}

<div class="container py-4">
    <h2 class="mb-4">Delete Supervisor</h2>

    <div class="alert alert-warning">
        Are you sure you want to delete this supervisor?
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Department</dt>
                <dd class="col-sm-9">@Model.Department</dd>

                <dt class="col-sm-3">Field of Expertise</dt>
                <dd class="col-sm-9">@Model.FieldOfExpertise</dd>

                <dt class="col-sm-3">Slots</dt>
                <dd class="col-sm-9">@Model.CurrentSlots / @Model.MaxSlots</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@(Model.IsActive ? "Active" : "Inactive")</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>