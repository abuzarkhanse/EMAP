@using EMAP.Domain.Fyp
@model ProposalSubmission

@{
    ViewData["Title"] = "Review Proposal";
}

<div class="container py-4">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Proposal Review</h2>
            <p class="text-muted mb-0">
                Review the submitted FYP proposal and take the academic decision.
            </p>
        </div>
        <a asp-action="Proposals" class="btn btn-outline-secondary btn-sm">
            Back to Proposals
        </a>
    </div>

    <div class="row g-4">

        <!-- Left: File Preview and Details -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <div class="row small mb-3">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Batch:</strong> @Model.Group.FypCall.Batch</p>
                            <p class="mb-1"><strong>Group Leader:</strong> @Model.Group.LeaderId</p>
                            <p class="mb-1"><strong>Supervisor:</strong> @Model.Group.Supervisor?.Name</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1">
                                <strong>Submitted:</strong>
                                @Model.SubmittedAt.ToString("dd MMM yyyy HH:mm")
                                (Revision @Model.RevisionNumber)
                            </p>
                            <p class="mb-1"><strong>Title:</strong> @Model.Title</p>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mb-3">
                        <a asp-controller="FilePreview"
                               asp-action="Proposal"
                               asp-route-id="@Model.Id"
                               class="btn btn-outline-primary btn-sm">
                            Preview File
                        </a>

                        <a href="@Model.FilePath"
                               target="_blank"
                               class="btn btn-outline-secondary btn-sm">
                            Download
                        </a>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.FilePath) &&
                                             Model.FilePath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <iframe src="@Model.FilePath"
                                style="width:100%; height:850px; border:0; border-radius:12px;">
                        </iframe>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            Inline browser preview is best supported for PDF files.
                            Use <strong>Preview File</strong> or <strong>Download</strong> for other file types.
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SupervisorFeedback))
                    {
                        <hr />
                        <p class="small text-muted mb-0">
                            <strong>Previous Feedback:</strong>
                            @Model.SupervisorFeedback
                        </p>
                    }
                </div>
            </div>
        </div>

        <!-- Right: Decision Panel -->
        <div class="col-lg-4">

            @if (Model.Status == ProposalStatus.PendingReview ||
                            Model.Status == ProposalStatus.ChangesRequested)
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body">
                        <h5 class="card-title text-success mb-2">
                            <i class="bi bi-check-circle me-2"></i>
                            Approve for Defense
                        </h5>

                        <p class="small text-muted">
                            Approve this proposal if it meets academic standards and is ready for defense scheduling.
                        </p>

                        <form asp-action="ApproveForDefense" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-success w-100">
                                Approve Proposal
                            </button>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title text-warning mb-2">
                            <i class="bi bi-pencil-square me-2"></i>
                            Request Changes
                        </h5>

                        <p class="small text-muted">
                            Send academic feedback and ask the group to revise and resubmit the proposal.
                        </p>

                        <form asp-action="RequestChanges" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="mb-3">
                                <label class="form-label small fw-semibold">
                                    Supervisor Feedback
                                </label>
                                <textarea name="feedback"
                                          class="form-control"
                                          rows="6"
                                          placeholder="Provide clear academic guidance for revision...">@Model.SupervisorFeedback</textarea>
                            </div>

                            <button type="submit" class="btn btn-outline-warning w-100">
                                Send Feedback & Request Revision
                            </button>
                        </form>
                    </div>
                </div>
            }
            else if (Model.Status == ProposalStatus.ApprovedForDefense)
            {
                <div class="alert alert-info">
                    <i class="bi bi-lock-fill me-1"></i>
                    Proposal is <strong>approved</strong>. Waiting for the FYP Coordinator to assign defense slot and time.
                </div>
            }
            else if (Model.Status == ProposalStatus.DefenseScheduled)
            {
                <div class="alert alert-success">
                    <i class="bi bi-calendar-check me-1"></i>
                    Defense is <strong>scheduled</strong>. Supervisor actions are now locked.
                </div>

                @if (Model.DefenseSchedule != null)
                {
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <h6 class="mb-3">Defense Schedule</h6>

                            <div><strong>Date:</strong> @Model.DefenseSchedule.DefenseDate.ToString("dd MMM yyyy")</div>
                            <div><strong>Time:</strong> @Model.DefenseSchedule.DefenseTime.ToString(@"hh\:mm")</div>
                            <div><strong>Duration:</strong> @Model.DefenseSchedule.DurationMinutes minutes</div>

                            @if (!string.IsNullOrWhiteSpace(Model.DefenseSchedule.Venue))
                            {
                                <div><strong>Venue:</strong> @Model.DefenseSchedule.Venue</div>
                            }

                            @if (!string.IsNullOrWhiteSpace(Model.DefenseSchedule.Instructions))
                            {
                                <hr />
                                <div class="small text-muted">
                                    <strong>Instructions:</strong>
                                    @Model.DefenseSchedule.Instructions
                                </div>
                            }
                        </div>
                    </div>
                }
            }

            <div class="alert alert-light small mt-4">
                <i class="bi bi-info-circle me-1"></i>
                Approved proposals move to coordinator scheduling. Proposals with requested changes must be revised and resubmitted by the student group.
            </div>
        </div>
    </div>
</div>
