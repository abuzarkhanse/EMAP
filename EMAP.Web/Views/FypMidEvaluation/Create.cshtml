@{
    ViewData["Title"] = "Create Evaluation";
}

<div class="mb-4">
    <div class="text-uppercase text-muted fw-semibold small">Coordinator Panel</div>
    <h2 class="mb-1">Create Evaluation</h2>
    <p class="text-muted mb-0">
        Schedule a Mid, Pre-Final, or Final evaluation for an approved student group.
    </p>
</div>

<form asp-action="Create" method="post" class="card shadow-sm border-0">
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                <label class="form-label fw-semibold">Evaluation Type / Milestone</label>
                <select name="milestoneId" class="form-select" asp-items="ViewBag.Milestones"></select>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Student Group</label>
                <select name="studentGroupId" class="form-select" asp-items="ViewBag.Groups"></select>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Weightage (%)</label>
                <input name="weightagePercent" type="number" step="0.01" min="0" max="100" class="form-control" value="20" />
                <small class="text-muted">Contribution of this evaluation in the final academic score.</small>
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Scheduled Date & Time</label>
                <input name="scheduledAt" type="datetime-local" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Venue</label>
                <input name="venue" class="form-control" placeholder="Seminar Hall / Lab / Room No." />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Committee Members</label>
                <input name="committeeMembers" class="form-control" placeholder="Coordinator / Committee members list" />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Instructions</label>
                <textarea name="instructions" rows="3" class="form-control" placeholder="Bring slides, report, and demo if required."></textarea>
            </div>
        </div>
    </div>

    <div class="card-footer bg-white d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create Evaluation</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</form>
