@model EMAP.Web.ViewModels.Fyp.EvaluationBulkCreateViewModel

@{
    ViewData["Title"] = "Create Evaluation";
}

<div class="mb-4">
    <div class="text-uppercase text-muted fw-semibold small">Coordinator Panel</div>
    <h2 class="mb-1">Create Evaluation</h2>
    <p class="text-muted mb-0">
        Schedule evaluations program-wise for all eligible student groups in your assigned committee.
    </p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="Create" method="get" class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label fw-semibold">Evaluation Type / Milestone</label>
                <select name="milestoneId" class="form-select" asp-items="ViewBag.Milestones"></select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-outline-primary w-100">Load Eligible Groups</button>
            </div>
        </div>
    </div>
</form>

<form asp-action="Create" method="post" class="card shadow-sm border-0">
    <div class="card-body">
        <input type="hidden" asp-for="MilestoneId" />

        <div class="row g-3 align-items-end mb-4">
            <div class="col-lg-2 col-md-4">
                <label asp-for="WeightagePercent" class="form-label fw-semibold">Weightage (%)</label>
                <input asp-for="WeightagePercent" type="number" step="0.01" min="0" max="100" class="form-control" />
            </div>

            <div class="col-lg-2 col-md-4">
                <label class="form-label fw-semibold">Scheduled Date</label>
                <input name="ScheduledDate" type="date" class="form-control" required />
            </div>

            <div class="col-lg-2 col-md-4">
                <label class="form-label fw-semibold">Scheduled Time</label>
                <input name="ScheduledTime" type="time" class="form-control" required />
            </div>

            <div class="col-lg-3 col-md-6">
                <label asp-for="Venue" class="form-label fw-semibold">Venue</label>
                <input asp-for="Venue" class="form-control" placeholder="Seminar Hall / Lab / Room No." />
            </div>

            <div class="col-lg-3 col-md-6">
                <label asp-for="CommitteeMembers" class="form-label fw-semibold">Committee Members</label>
                <input asp-for="CommitteeMembers" class="form-control" placeholder="Coordinator / Committee members list" />
            </div>

            <div class="col-12">
                <label asp-for="Instructions" class="form-label fw-semibold">Instructions</label>
                <textarea asp-for="Instructions" rows="3" class="form-control" placeholder="Bring slides, report, demo, or report copy if required."></textarea>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Eligible Groups</h5>
            <span class="text-muted small">@Model.EligibleGroups.Count group(s) found</span>
        </div>

        @if (!Model.EligibleGroups.Any())
        {
            <div class="alert alert-warning mb-0">
                No eligible groups found for the selected milestone. Select a milestone first or check group readiness.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:60px;">
                                <input type="checkbox" id="checkAll" />
                            </th>
                            <th>Group</th>
                            <th>Program</th>
                            <th>Batch</th>
                            <th>Supervisor</th>
                            <th>Stage</th>
                            <th>Eligibility</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.EligibleGroups.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox"
                                           name="SelectedGroupIds"
                                           value="@Model.EligibleGroups[i].GroupId" />
                                </td>
                                <td>
                                    <div class="fw-semibold">@Model.EligibleGroups[i].ProjectTitle</div>
                                    <div class="text-muted small">Group #@Model.EligibleGroups[i].GroupId</div>
                                </td>
                                <td>@Model.EligibleGroups[i].ProgramCode</td>
                                <td>@Model.EligibleGroups[i].Batch</td>
                                <td>@Model.EligibleGroups[i].SupervisorName</td>
                                <td>
                                    <span class="badge bg-secondary">@Model.EligibleGroups[i].Stage</span>
                                </td>
                                <td>@Model.EligibleGroups[i].ReadinessText</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card-footer bg-white d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create Evaluation(s)</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</form>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const checkAll = document.getElementById("checkAll");
        if (!checkAll) return;

        checkAll.addEventListener("change", function () {
            document.querySelectorAll('input[name="SelectedGroupIds"]').forEach(cb => {
                cb.checked = checkAll.checked;
            });
        });
    });
</script>
