@model EMAP.Web.ViewModels.Fyp.FypMidEvaluationFormViewModel

@{
    ViewData["Title"] = "Per Member Mid Evaluation";
    var totalMax = Model.Criteria.Sum(x => x.MaxMarks);
}

<div class="container py-4">
    <div class="mb-4">
        <div class="text-uppercase text-muted fw-semibold small">Coordinator Assessment Panel</div>
        <h2 class="mb-2">Mid Evaluation — Per Member Rubric</h2>
        <p class="text-muted mb-0">
            Each student is evaluated separately under the same group evaluation session.
        </p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="fw-semibold text-dark">Project Title</div>
                    <div>@Model.ProjectTitle</div>
                </div>
                <div class="col-md-2">
                    <div class="fw-semibold text-dark">Group ID</div>
                    <div>@Model.GroupId</div>
                </div>
                <div class="col-md-2">
                    <div class="fw-semibold text-dark">Batch</div>
                    <div>@Model.Batch</div>
                </div>
                <div class="col-md-2">
                    <div class="fw-semibold text-dark">Program</div>
                    <div>@Model.ProgramCode</div>
                </div>
                <div class="col-md-2">
                    <div class="fw-semibold text-dark">Weightage</div>
                    <div>@Model.WeightagePercent %</div>
                </div>
                <div class="col-md-4">
                    <div class="fw-semibold text-dark">Supervisor</div>
                    <div>@Model.SupervisorName</div>
                </div>
                <div class="col-md-4">
                    <div class="fw-semibold text-dark">Scheduled</div>
                    <div>@(Model.ScheduledAt?.ToString("dd MMM yyyy hh:mm tt") ?? "-")</div>
                </div>
                <div class="col-md-4">
                    <div class="fw-semibold text-dark">Venue</div>
                    <div>@Model.Venue</div>
                </div>
            </div>
        </div>
    </div>

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="EvaluationId" />
        <input type="hidden" asp-for="GroupId" />
        <input type="hidden" asp-for="ProjectTitle" />
        <input type="hidden" asp-for="Batch" />
        <input type="hidden" asp-for="ProgramCode" />
        <input type="hidden" asp-for="SupervisorName" />
        <input type="hidden" asp-for="ScheduledAt" />
        <input type="hidden" asp-for="Venue" />
        <input type="hidden" asp-for="WeightagePercent" />

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body bg-light">
                <div class="row g-3 align-items-end">
                    <div class="col-md-6">
                        <label asp-for="EvaluatorName" class="form-label fw-semibold">Evaluator Name</label>
                        <input asp-for="EvaluatorName" class="form-control" />
                        <span asp-validation-for="EvaluatorName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="OverallRemarks" class="form-label fw-semibold">Overall Evaluation Comment</label>
                        <textarea asp-for="OverallRemarks" rows="2" class="form-control"></textarea>
                    </div>
                </div>
            </div>
        </div>

        @for (int i = 0; i < Model.Members.Count; i++)
        {
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-0">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                        <div>
                            <h4 class="mb-1">@Model.Members[i].StudentName</h4>
                            <div class="text-muted small">
                                @(!string.IsNullOrWhiteSpace(Model.Members[i].RegistrationNo) ? Model.Members[i].RegistrationNo : "Group Member")
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="small text-muted">Student Total</div>
                            <div class="fw-bold fs-5">
                                <span class="member-total" data-member-index="@i">@Model.Members[i].TotalMarks</span> / @totalMax
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <input type="hidden" asp-for="Members[i].EvaluationMemberId" />
                    <input type="hidden" asp-for="Members[i].StudentUserId" />
                    <input type="hidden" asp-for="Members[i].StudentName" />
                    <input type="hidden" asp-for="Members[i].RegistrationNo" />

                    <div class="table-responsive">
                        <table class="table table-bordered align-middle rubric-table">
                            <thead class="table-light">
                                <tr>
                                    <th style="min-width:260px;">Criterion</th>
                                    <th style="width:120px;">Max</th>
                                    <th style="width:150px;">Marks</th>
                                    <th style="min-width:260px;">Comment</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int j = 0; j < Model.Members[i].Scores.Count; j++)
                                {
                                    <tr>
                                        <td>
                                            <strong>@Model.Members[i].Scores[j].CriterionTitle</strong>
                                            <input type="hidden" asp-for="Members[i].Scores[j].CriterionId" />
                                            <input type="hidden" asp-for="Members[i].Scores[j].CriterionTitle" />
                                            <input type="hidden" asp-for="Members[i].Scores[j].MaxMarks" />
                                        </td>
                                        <td>@Model.Members[i].Scores[j].MaxMarks</td>
                                        <td>
                                            <input asp-for="Members[i].Scores[j].AwardedMarks"
                                                   class="form-control member-mark-input"
                                                   type="number"
                                                   step="0.5"
                                                   min="0"
                                                   max="@Model.Members[i].Scores[j].MaxMarks"
                                                   data-member-index="@i" />
                                        </td>
                                        <td>
                                            <input asp-for="Members[i].Scores[j].Comment" class="form-control" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Members[i].Remarks" class="form-label fw-semibold">Student Remarks</label>
                        <textarea asp-for="Members[i].Remarks" rows="2" class="form-control"></textarea>
                    </div>
                </div>
            </div>
        }

        <div class="d-flex justify-content-end gap-2 pb-4">
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
            <button type="submit" class="btn btn-primary">Save Evaluation</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function updateMemberTotals() {
            const totals = {};

            document.querySelectorAll('.member-mark-input').forEach(input => {
                const idx = input.dataset.memberIndex;
                const value = parseFloat(input.value || '0');
                totals[idx] = (totals[idx] || 0) + value;
            });

            document.querySelectorAll('.member-total').forEach(span => {
                const idx = span.dataset.memberIndex;
                span.textContent = (totals[idx] || 0).toFixed(2);
            });
        }

        document.querySelectorAll('.member-mark-input').forEach(input => {
            input.addEventListener('input', updateMemberTotals);
        });

        updateMemberTotals();
    </script>
}
