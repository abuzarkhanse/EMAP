@model EMAP.Web.ViewModels.Fyp.FypMidEvaluationFormViewModel

@{
    ViewData["Title"] = "Mid Evaluation";
}

<div class="mid-eval-page">
    <div class="mb-4">
        <h2 class="mid-eval-title">Mid Evaluation Form</h2>
        <p class="mid-eval-subtitle">
            Structured committee-based assessment for FYP mid evaluation.
        </p>
    </div>

    <form asp-action="Evaluate" method="post">
        <input asp-for="EvaluationId" type="hidden" />
        <input asp-for="StudentGroupId" type="hidden" />
        <input asp-for="GroupTitle" type="hidden" />
        <input asp-for="Batch" type="hidden" />
        <input asp-for="ProgramCode" type="hidden" />
        <input asp-for="SupervisorName" type="hidden" />
        <input asp-for="Venue" type="hidden" />
        <input asp-for="ScheduledAt" type="hidden" />
        <input asp-for="WeightagePercent" type="hidden" />

        <!-- GROUP + EVALUATION INFO -->
        <div class="card shadow-sm border-0 mid-eval-info-card mb-4">
            <div class="card-body">
                <div class="mid-eval-section-head mb-3">
                    <h4 class="mb-1">Evaluation Details</h4>
                    <p class="text-muted mb-0">Group profile, schedule, and academic evaluation metadata.</p>
                </div>

                <div class="row g-4">
                    <div class="col-lg-4">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Project / Group Title</div>
                            <div class="mid-eval-value">@Model.GroupTitle</div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Group ID</div>
                            <div class="mid-eval-value">@Model.StudentGroupId</div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Batch</div>
                            <div class="mid-eval-value">@Model.Batch</div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Program</div>
                            <div class="mid-eval-value">@Model.ProgramCode</div>
                        </div>
                    </div>

                    <div class="col-lg-2 col-md-4">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Weightage</div>
                            <div class="mid-eval-value">@Model.WeightagePercent %</div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Supervisor</div>
                            <div class="mid-eval-value">@Model.SupervisorName</div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Scheduled</div>
                            <div class="mid-eval-value">
                                @(Model.ScheduledAt?.ToString("dd MMM yyyy hh:mm tt") ?? "-")
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4 col-md-6">
                        <div class="mid-eval-info-box">
                            <div class="mid-eval-label">Venue</div>
                            <div class="mid-eval-value">@Model.Venue</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- RUBRIC SUMMARY -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="mid-eval-summary-banner">
                    <div>
                        <strong>Rubric Structure:</strong>
                        8 criteria × 5 marks each
                    </div>
                    <div>
                        <strong>Total:</strong> 40
                    </div>
                    <div>
                        <strong>Weighted Result:</strong>
                        Based on @Model.WeightagePercent%
                    </div>
                </div>
            </div>
        </div>

        <!-- RUBRIC TABLE -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="mid-eval-section-head mb-3">
                    <h4 class="mb-1">Rubric Assessment</h4>
                    <p class="text-muted mb-0">Enter awarded marks and optional comments for each criterion.</p>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle text-center mid-rubric-table">
                        <thead>
                            <tr>
                                @for (int i = 0; i < Model.Criteria.Count; i++)
                                {
                                    <th style="min-width:170px;">
                                        <input asp-for="Criteria[@i].CriterionId" type="hidden" />
                                        <input asp-for="Criteria[@i].Title" type="hidden" />
                                        <input asp-for="Criteria[@i].Description" type="hidden" />
                                        <input asp-for="Criteria[@i].MaxMarks" type="hidden" />

                                        <div class="mid-rubric-title">@Model.Criteria[i].Title</div>
                                        <div class="mid-rubric-max">Max: 5</div>
                                    </th>
                                }
                                <th style="min-width:130px;">Total</th>
                                <th style="min-width:150px;">Weighted</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                @for (int i = 0; i < Model.Criteria.Count; i++)
                                {
                                    <td>
                                        <input asp-for="Criteria[@i].AwardedMarks"
                                               class="form-control text-center score-input mid-score-input"
                                               type="number"
                                               step="0.5"
                                               min="0"
                                               max="5"
                                               placeholder="0-5" />
                                    </td>
                                }

                                <td>
                                    <input type="text" id="totalBox" class="form-control fw-bold text-center mid-total-box" readonly />
                                </td>

                                <td>
                                    <input type="text" id="weightedBox" class="form-control fw-bold text-center mid-total-box" readonly />
                                </td>
                            </tr>

                            <tr>
                                @for (int i = 0; i < Model.Criteria.Count; i++)
                                {
                                    <td>
                                        <input asp-for="Criteria[@i].Comment"
                                               class="form-control mid-comment-input"
                                               placeholder="Comment" />
                                    </td>
                                }

                                <td class="fw-semibold align-middle bg-light">/ 40</td>
                                <td class="fw-semibold align-middle bg-light">/ @Model.WeightagePercent</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- FINAL REMARKS -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="mid-eval-section-head mb-3">
                    <h4 class="mb-1">Final Evaluation Notes</h4>
                    <p class="text-muted mb-0">Provide evaluator identity and overall academic remarks.</p>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="EvaluatorName" class="form-label fw-semibold">Evaluator Name</label>
                        <input asp-for="EvaluatorName" class="form-control" placeholder="Enter evaluator name" />
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Remarks" class="form-label fw-semibold">Evaluation Comment</label>
                        <textarea asp-for="Remarks" rows="4" class="form-control"
                                  placeholder="Write overall evaluation comments, strengths, weaknesses, and recommendations."></textarea>
                    </div>
                </div>
            </div>

            <div class="card-footer bg-white d-flex gap-2">
                <button type="submit" class="btn btn-success">Submit Evaluation</button>
                <a asp-action="MyAssigned" class="btn btn-secondary">Back</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateTotals() {
            let total = 0;
            document.querySelectorAll('.score-input').forEach(function (input) {
                const val = parseFloat(input.value);
                if (!isNaN(val)) total += val;
            });

            const weightage = parseFloat('@Model.WeightagePercent');
            const weighted = weightage > 0 ? ((total / 40.0) * weightage) : 0;

            document.getElementById('totalBox').value = total.toFixed(2);
            document.getElementById('weightedBox').value = weighted.toFixed(2);
        }

        document.querySelectorAll('.score-input').forEach(function (input) {
            input.addEventListener('input', updateTotals);
        });

        updateTotals();
    </script>
}
