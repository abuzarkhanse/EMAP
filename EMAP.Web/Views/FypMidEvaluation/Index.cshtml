@model IEnumerable<EMAP.Domain.Fyp.FypEvaluation>

@{
    ViewData["Title"] = "Mid Evaluations";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Mid Evaluations</h2>
    <a asp-action="Create" class="btn btn-primary">Create Mid Evaluation</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Group</th>
                    <th>Program</th>
                    <th>Batch</th>
                    <th>Scheduled</th>
                    <th>Venue</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.StudentGroup?.TentativeProjectTitle</td>
                        <td>@item.StudentGroup?.ProgramCode</td>
                        <td>@item.StudentGroup?.FypCall?.Batch</td>
                        <td>@(item.ScheduledAt?.ToString("dd MMM yyyy hh:mm tt") ?? "-")</td>
                        <td>@item.Venue</td>
                        <td>@item.TotalMarks</td>
                        <td>
                            @if (item.IsSubmitted)
                            {
                                <span class="badge bg-success">Submitted</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Evaluate" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Open</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
