@model EMAP.Web.ViewModels.Fyp.FypEvaluationCriterionFormViewModel

@{
    ViewData["Title"] = "Add Rubric";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Add Evaluation Rubric</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">

                    <!-- Evaluation Type -->
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Evaluation Type</label>
                        <select asp-for="EvaluationType"
                                asp-items="ViewBag.EvaluationTypes"
                                class="form-select"></select>
                        <span asp-validation-for="EvaluationType" class="text-danger"></span>
                    </div>

                    <!-- Display Order -->
                    <div class="col-md-2">
                        <label asp-for="DisplayOrder" class="form-label fw-semibold"></label>
                        <input asp-for="DisplayOrder" class="form-control" />
                        <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                    </div>

                    <!-- Max Marks -->
                    <div class="col-md-2">
                        <label asp-for="MaxMarks" class="form-label fw-semibold"></label>
                        <input asp-for="MaxMarks" class="form-control" step="0.5" />
                        <span asp-validation-for="MaxMarks" class="text-danger"></span>
                    </div>

                    <!-- Active -->
                    <div class="col-md-4 d-flex align-items-center">
                        <div class="form-check form-switch mt-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">
                                Active Rubric
                            </label>
                        </div>
                    </div>

                    <!-- Title -->
                    <div class="col-md-12">
                        <label asp-for="Title" class="form-label fw-semibold"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" rows="3" class="form-control"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                </div>

                <hr />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-success">
                        Save Rubric
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
