@model IEnumerable<EMAP.Domain.Fyp.FypMilestone>
@using EMAP.Domain.Fyp

@{
    ViewData["Title"] = "FYP Milestones";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-1">FYP Milestones</h3>
                <small class="text-muted">Manage FYP-1 and FYP-2 chapter and evaluation milestones.</small>
            </div>
            <a asp-action="Create" class="btn btn-primary">Add Milestone</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Stage</th>
                            <th>Type</th>
                            <th>Chapter</th>
                            <th>Order</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th>Optional</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                    {
                                        <small class="text-muted">@item.Description</small>
                                    }
                                </td>
                                <td>@item.Stage</td>
                                <td>@item.Type</td>
                                <td>@(item.ChapterNumber?.ToString() ?? "-")</td>
                                <td>@item.DisplayOrder</td>
                                <td>@(item.DueDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsOptional)
                                    {
                                        <span class="badge bg-warning-subtle text-warning">Optional</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">Required</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">
                                        Edit
                                    </a>

                                    <form asp-action="ToggleActive" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                                            @(item.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>