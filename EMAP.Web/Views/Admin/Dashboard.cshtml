@model EMAP.Web.Controllers.AdminDashboardViewModel

@{
    ViewData["Title"] = "FYP Admin Dashboard";
}

<div class="container py-4 admin-dashboard-page">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">EMAP – FYP Administration</h2>
            <p class="text-muted mb-0">
                Central academic control panel for FYP calls, supervisors, committees, student groups, and proposals.
            </p>
        </div>

        <div>
            <span class="badge bg-primary-subtle border border-primary text-primary px-3 py-2">
                <i class="bi bi-mortarboard me-1"></i>
                Academic Session @DateTime.Now.Year / @(DateTime.Now.Year + 1)
            </span>
        </div>
    </div>

    <!-- Summary Metrics -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm border-0 h-100 admin-summary-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="admin-summary-icon bg-primary">
                            <i class="bi bi-megaphone-fill"></i>
                        </div>
                        <div>
                            <div class="text-muted small">FYP Calls</div>
                            <div class="fs-4 fw-semibold">@Model.ActiveCalls <span class="text-muted">/ @Model.TotalCalls</span></div>
                            <div class="small text-muted">Active / Total</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm border-0 h-100 admin-summary-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="admin-summary-icon bg-success">
                            <i class="bi bi-person-badge-fill"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Supervisors</div>
                            <div class="fs-4 fw-semibold">@Model.ActiveSupervisors <span class="text-muted">/ @Model.TotalSupervisors</span></div>
                            <div class="small text-muted">Slots used: @Model.UsedSupervisorSlots / @Model.TotalSupervisorSlots</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm border-0 h-100 admin-summary-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="admin-summary-icon bg-info">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Student Groups</div>
                            <div class="fs-4 fw-semibold">@Model.TotalGroups</div>
                            <div class="small text-muted">Pending supervisor decision: @Model.PendingSupervisorRequests</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm border-0 h-100 admin-summary-card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="admin-summary-icon bg-warning">
                            <i class="bi bi-journal-text"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Proposals</div>
                            <div class="fw-semibold">Pending: @Model.PendingProposals</div>
                            <div class="small text-muted">
                                Changes requested: @Model.ChangesRequestedProposals<br />
                                Approved / ready: @Model.ApprovedProposals
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Grid -->
    <div class="row g-4">

        <!-- Left: Admin Modules -->
        <div class="col-lg-8">

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-2">
                        <i class="bi bi-grid-1x2 me-2"></i>Academic Administration Modules
                    </h5>
                    <p class="small text-muted mb-4">
                        Use these modules to manage the full university FYP workflow in one consistent academic control center.
                    </p>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <a asp-controller="FypCall" asp-action="Index" class="text-decoration-none">
                                <div class="card border-0 shadow-sm h-100 admin-module-card">
                                    <div class="card-body">
                                        <div class="admin-module-icon bg-primary-subtle text-primary">
                                            <i class="bi bi-megaphone"></i>
                                        </div>
                                        <h6 class="mt-3 mb-2">FYP Calls</h6>
                                        <p class="text-muted small mb-0">
                                            Define academic batches, timelines, proposal deadlines, and active sessions.
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a asp-controller="Supervisor" asp-action="Index" class="text-decoration-none">
                                <div class="card border-0 shadow-sm h-100 admin-module-card">
                                    <div class="card-body">
                                        <div class="admin-module-icon bg-success-subtle text-success">
                                            <i class="bi bi-person-badge"></i>
                                        </div>
                                        <h6 class="mt-3 mb-2">Supervisor Directory</h6>
                                        <p class="text-muted small mb-0">
                                            Manage supervisor profiles, research expertise, active capacity, and slot usage.
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a asp-controller="FypCommittee" asp-action="Index" class="text-decoration-none">
                                <div class="card border-0 shadow-sm h-100 admin-module-card">
                                    <div class="card-body">
                                        <div class="admin-module-icon bg-info-subtle text-info">
                                            <i class="bi bi-diagram-3"></i>
                                        </div>
                                        <h6 class="mt-3 mb-2">FYP Committees</h6>
                                        <p class="text-muted small mb-1">
                                            Manage coordinators, committees, and program mapping.
                                        </p>
                                        <div class="small text-muted">
                                            Active: @Model.ActiveCommittees / @Model.TotalCommittees
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a asp-controller="Supervisor" asp-action="Proposals" class="text-decoration-none">
                                <div class="card border-0 shadow-sm h-100 admin-module-card">
                                    <div class="card-body">
                                        <div class="admin-module-icon bg-warning-subtle text-warning">
                                            <i class="bi bi-file-earmark-text"></i>
                                        </div>
                                        <h6 class="mt-3 mb-2">Proposals Overview</h6>
                                        <p class="text-muted small mb-0">
                                            Monitor proposal progress, review load, pending cases, and defense readiness.
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                        <div class="col-md-6">
                            <a asp-controller="FypFinalRecordAdmin" asp-action="Index" class="text-decoration-none">
                                <div class="card border-0 shadow-sm h-100 admin-module-card">
                                    <div class="card-body">
                                        <div class="admin-module-icon bg-secondary-subtle text-secondary">
                                            <i class="bi bi-archive"></i>
                                        </div>
                                        <h6 class="mt-3 mb-2">Final Academic Records</h6>
                                        <p class="text-muted small mb-0">
                                            Review completed FYP dossiers submitted by coordinators, process final records, and manage archival history.
                                        </p>
                                    </div>
                                </div>
                            </a>
                        </div>

                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="bi bi-bar-chart-line me-2"></i>Administrative Focus
                    </h5>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="admin-mini-stat">
                                <div class="admin-mini-stat-label">Calls Running</div>
                                <div class="admin-mini-stat-value">@Model.ActiveCalls</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="admin-mini-stat">
                                <div class="admin-mini-stat-label">Pending Requests</div>
                                <div class="admin-mini-stat-value">@Model.PendingSupervisorRequests</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="admin-mini-stat">
                                <div class="admin-mini-stat-label">Proposal Queue</div>
                                <div class="admin-mini-stat-value">@Model.PendingProposals</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Right: Guidance -->
        <div class="col-lg-4">

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">
                        <i class="bi bi-lightbulb me-2"></i>Admin Guidance
                    </h5>
                    <ol class="small mb-0 ps-3">
                        <li class="mb-2">Publish or update <strong>FYP Calls</strong> at the start of each academic cycle.</li>
                        <li class="mb-2">Maintain the <strong>Supervisor Directory</strong> so students can select valid supervisors.</li>
                        <li class="mb-2">Review <strong>committee mapping</strong> carefully for program-wise coordination.</li>
                        <li class="mb-2">Track <strong>pending supervisor requests</strong> to avoid student delays.</li>
                        <li>Ensure <strong>proposals</strong> move from pending to defense-ready without bottlenecks.</li>
                    </ol>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h6 class="card-title mb-2">
                        <i class="bi bi-info-circle me-2"></i>Academic Snapshot
                    </h6>
                    <p class="small text-muted mb-0">
                        This dashboard is designed for quality assurance, workload monitoring, and academic coordination.
                        It gives a quick view of participation, supervision capacity, committee structure, and proposal progress.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="card-title mb-3">
                        <i class="bi bi-check2-square me-2"></i>Current Admin Priorities
                    </h6>

                    <div class="small">
                        <div class="mb-2">
                            <strong>Supervisor load:</strong> @Model.UsedSupervisorSlots / @Model.TotalSupervisorSlots slots used
                        </div>
                        <div class="mb-2">
                            <strong>Committees active:</strong> @Model.ActiveCommittees / @Model.TotalCommittees
                        </div>
                        <div class="mb-2">
                            <strong>Groups formed:</strong> @Model.TotalGroups
                        </div>
                        <div>
                            <strong>Defense-ready proposals:</strong> @Model.ApprovedProposals
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
