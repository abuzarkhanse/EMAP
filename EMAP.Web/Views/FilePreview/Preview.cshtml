@model EMAP.Web.Controllers.FilePreviewVm

@{
    ViewData["Title"] = "File Preview";
}

<div class="container py-4">
    <div class="mb-4">
        <div class="text-uppercase text-muted fw-semibold small">@Model.FileTypeLabel</div>
        <h2 class="mb-1">@Model.Title</h2>
        <p class="text-muted mb-0">@Model.Subtitle</p>
    </div>

    <div class="row g-4">
        <!-- Left: Preview -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    @if (Model.IsPdf)
                    {
                        <iframe src="@Model.FilePath"
                                style="width:100%; height:850px; border:0; border-radius:12px;">
                        </iframe>
                    }
                    else if (Model.IsImage)
                    {
                        <div class="text-center">
                            <img src="@Model.FilePath" class="img-fluid rounded" alt="Preview file" />
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            Browser preview is not fully supported for this file type.
                            Please use <strong>Open in New Tab</strong> or <strong>Download</strong>.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right: Info / Actions -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h5 class="mb-3">File Information</h5>

                    <div class="mb-3">
                        <div class="text-muted small">@Model.Meta1Label</div>
                        <div class="fw-semibold">@Model.Meta1Value</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">@Model.Meta2Label</div>
                        <div class="fw-semibold">@Model.Meta2Value</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">@Model.Meta3Label</div>
                        <div class="fw-semibold">@Model.Meta3Value</div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="mb-3">Actions</h5>

                    <div class="d-grid gap-2">
                        <a href="@Model.FilePath" target="_blank" class="btn btn-primary">
                            Open in New Tab
                        </a>

                        <a href="@Model.FilePath" download class="btn btn-outline-secondary">
                            Download File
                        </a>

                        <button type="button" class="btn btn-outline-dark" onclick="history.back()">
                            Back
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
