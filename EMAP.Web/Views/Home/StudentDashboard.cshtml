@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container py-4 student-dashboard-page">

    <!-- Header -->
    <div class="dashboard-topbar mb-4">
        <div>
            <h1 class="dashboard-heading mb-1">Student Dashboard</h1>
            <p class="dashboard-subheading mb-0">
                Access your academic project workspace and follow your current progress.
            </p>
        </div>

        <div class="dashboard-user-pill">
            <i class="bi bi-person-circle me-2"></i>
            @User.Identity?.Name
        </div>
    </div>

    <!-- Main hero -->
    <section class="student-hero-card mb-4">
        <div class="student-hero-content">
            <div class="student-hero-left">
                <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                    <h2 class="mb-0">Final Year Project</h2>
                    <span class="dashboard-status-pill">Active</span>
                </div>

                <p class="student-hero-text">
                    Use your FYP workspace to manage group formation, supervisor selection,
                    proposal progress, defense workflow, and chapter submissions.
                </p>

                <div class="dashboard-feature-tags">
                    <span>Group & supervisor</span>
                    <span>Proposal progress</span>
                    <span>Defense workflow</span>
                    <span>Chapter submissions</span>
                </div>
            </div>

            <div class="student-hero-actions">
                <a asp-controller="Fyp" asp-action="Index"
                   class="btn btn-primary student-main-btn">
                    Open FYP Portal
                </a>

                <a href="/templates/SRS%20Template.docx"
                   class="btn btn-light student-secondary-btn"
                   download>
                    View Guidelines
                </a>
            </div>
        </div>
    </section>

    <!-- Secondary grid -->
    <div class="dashboard-grid-student">

        <!-- Next Step -->
        <section class="student-card student-card-highlight">
            <div class="student-card-icon">
                <i class="bi bi-lightning-charge"></i>
            </div>

            <div class="student-card-body">
                <h3>Your Next Step</h3>
                <p class="student-card-text">
                    Continue your FYP work from the portal and complete the next required task.
                </p>

                <div class="student-next-step-box">
                    <div class="student-next-step-label">Recommended action</div>
                    <div class="student-next-step-title">Go to FYP Portal</div>
                </div>

                <div class="student-link-list">
                    <a href="#">View My Submissions</a>
                    <a href="#">Supervisor Feedback</a>
                    <a href="/templates/SRS%20Template.docx" download>Download Templates</a>
                </div>
            </div>

            <div class="student-card-footer">
                <a asp-controller="Fyp" asp-action="Index"
                   class="btn btn-sm btn-outline-primary admin-action-btn">
                    Continue
                </a>
            </div>
        </section>

        <!-- Deadlines -->
        <section class="student-card">
            <div class="student-card-icon">
                <i class="bi bi-calendar-event"></i>
            </div>

            <div class="student-card-body">
                <h3>Upcoming Deadlines</h3>

                <div class="student-info-list">
                    <div class="student-info-item">
                        <div class="student-info-title">FYP Proposal Submission</div>
                        <div class="student-info-meta">Due: 15 Dec 2025</div>
                        <span class="student-warning-chip">5 days remaining</span>
                    </div>

                    <div class="student-info-item">
                        <div class="student-info-title">Supervisor Approval</div>
                        <div class="student-info-meta">Due: 22 Dec 2025</div>
                    </div>

                    <div class="student-info-item">
                        <div class="student-info-title">Progress Presentation</div>
                        <div class="student-info-meta">Tentative: Jan 2026</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Activity -->
        <section class="student-card">
            <div class="student-card-icon">
                <i class="bi bi-clock-history"></i>
            </div>

            <div class="student-card-body">
                <h3>Recent Activity</h3>

                <div class="student-activity-list">
                    <div class="student-activity-item">
                        <span class="activity-dot success"></span>
                        <div>
                            <div class="student-info-title">Proposal draft saved</div>
                            <div class="student-info-meta">Today, 10:45 AM</div>
                        </div>
                    </div>

                    <div class="student-activity-item">
                        <span class="activity-dot info"></span>
                        <div>
                            <div class="student-info-title">Supervisor notification received</div>
                            <div class="student-info-meta">Yesterday</div>
                        </div>
                    </div>

                    <div class="student-activity-item">
                        <span class="activity-dot muted"></span>
                        <div>
                            <div class="student-info-title">Template downloaded</div>
                            <div class="student-info-meta">2 days ago</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

    </div>
</div>