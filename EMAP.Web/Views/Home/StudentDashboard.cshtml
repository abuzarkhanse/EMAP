@model EMAP.Web.ViewModels.Fyp.StudentDashboardViewModel
@using EMAP.Domain.Fyp

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container py-4 student-dashboard-page">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1 class="dashboard-heading mb-1">Student Dashboard</h1>
            <p class="text-muted mb-0">
                Track your FYP progress, current academic stage, deadlines, and required next action.
            </p>
        </div>

        <div class="dashboard-user-pill">
            <i class="bi bi-person-circle me-2"></i>
            @Model.StudentName
        </div>
    </div>

    @if (Model.Group != null && Model.Group.IsFypCompleted)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            <h5 class="mb-2">Final Year Project Completed Successfully</h5>
            <p class="mb-0">
                Your group has successfully completed all FYP academic requirements.
                The project has been finalized by the coordinator and is now ready for administrative record processing.
            </p>
        </div>
    }

    <!-- HERO SUMMARY -->
    <section class="student-hero-card mb-4">
        <div class="student-hero-content">
            <div class="student-hero-left">
                <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                    <h2 class="mb-0">Final Year Project</h2>
                    <span class="dashboard-status-pill">@Model.CurrentStageLabel</span>
                    <span class="badge bg-info text-dark">@Model.CurrentStatusLabel</span>
                </div>

                @if (Model.HasGroup)
                {
                    <div class="row g-3 small mt-1">
                        <div class="col-md-4">
                            <div class="text-muted">Project Title</div>
                            <div class="fw-semibold">@Model.Group!.TentativeProjectTitle</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Group</div>
                            <div class="fw-semibold">#@Model.Group!.Id</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Program</div>
                            <div class="fw-semibold">@Model.Group!.ProgramCode</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Batch</div>
                            <div class="fw-semibold">@Model.ActiveBatch</div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-muted">Supervisor</div>
                            <div class="fw-semibold">@(Model.Group!.Supervisor?.Name ?? "-")</div>
                        </div>
                    </div>
                }
                else
                {
                    <p class="student-hero-text mb-0">
                        You are not yet part of an FYP group. Create a group to begin your academic workflow.
                    </p>
                }
            </div>

            <div class="student-hero-actions">
                <a asp-controller="@Model.NextActionController"
                       asp-action="@Model.NextActionAction"
                       class="btn btn-primary student-main-btn">
                    @Model.NextActionButtonText
                </a>

                <a asp-controller="Fyp"
                       asp-action="Index"
                       class="btn btn-light student-secondary-btn">
                    Open FYP Portal
                </a>
            </div>
        </div>
    </section>

    <div class="row g-4">

        <!-- LEFT SIDE -->
        <div class="col-lg-8">

            <!-- NEXT ACTION -->
            <section class="student-card student-card-highlight mb-4">
                <div class="student-card-icon">
                    <i class="bi bi-lightning-charge"></i>
                </div>

                <div class="student-card-body">
                    <h3>Your Next Required Action</h3>
                    <p class="student-card-text">@Model.NextActionDescription</p>

                    <div class="student-next-step-box">
                        <div class="student-next-step-label">Recommended action</div>
                        <div class="student-next-step-title">@Model.NextActionTitle</div>
                    </div>
                </div>

                <div class="student-card-footer">
                    <a asp-controller="@Model.NextActionController"
                           asp-action="@Model.NextActionAction"
                           class="btn btn-sm btn-outline-primary admin-action-btn">
                        @Model.NextActionButtonText
                    </a>

                    <a href="/templates/SRS%20Template.docx" class="btn btn-outline-secondary btn-sm" download>
                        Download Template
                    </a>
                </div>
            </section>

            <!-- CURRENT ACADEMIC STATUS -->
            <section class="student-card mb-4">
                <div class="student-card-icon">
                    <i class="bi bi-mortarboard"></i>
                </div>

                <div class="student-card-body">
                    <h3>Current Academic Status</h3>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <div class="student-info-item">
                                <div class="student-info-title">Group Status</div>
                                <div class="student-info-meta">@(Model.Group?.Status.ToString() ?? "Not Created")</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="student-info-item">
                                <div class="student-info-title">Proposal Status</div>
                                <div class="student-info-meta">@(Model.Proposal?.Status.ToString() ?? "Not Submitted")</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="student-info-item">
                                <div class="student-info-title">Defense</div>
                                <div class="student-info-meta">
                                    @if (Model.DefenseEvaluation != null)
                                    {
                                        <span>Completed</span>
                                    }
                                    else if (Model.DefenseSchedule != null)
                                    {
                                        <span>Scheduled</span>
                                    }
                                    else
                                    {
                                        <span>Pending</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="student-info-item">
                                <div class="student-info-title">Chapter Progress</div>
                                <div class="student-info-meta">@Model.CompletedChaptersCount / @Model.TotalStageChapters completed</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="student-info-item">
                                <div class="student-info-title">Published Evaluations</div>
                                <div class="student-info-meta">@Model.PublishedEvaluationsCount available</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="student-info-item">
                                <div class="student-info-title">Current Stage</div>
                                <div class="student-info-meta">@Model.CurrentStageLabel</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>

        <!-- RIGHT SIDE -->
        <div class="col-lg-4">

            <!-- UPCOMING -->
            <section class="student-card mb-4">
                <div class="student-card-icon">
                    <i class="bi bi-calendar-event"></i>
                </div>

                <div class="student-card-body">
                    <h3>Upcoming Important Item</h3>

                    @if (!string.IsNullOrWhiteSpace(Model.UpcomingTitle))
                    {
                        <div class="student-info-list">
                            <div class="student-info-item">
                                <div class="student-info-title">@Model.UpcomingTitle</div>
                                <div class="student-info-meta">@Model.UpcomingDateText</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(Model.UpcomingSecondaryTitle))
                            {
                                <div class="student-info-item">
                                    <div class="student-info-title">@Model.UpcomingSecondaryTitle</div>
                                    <div class="student-info-meta">@Model.UpcomingSecondaryDateText</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No immediate academic deadline or scheduled event is available right now.</p>
                    }
                </div>
            </section>

            <!-- HELP / INFORMATION -->
            <section class="student-card">
                <div class="student-card-icon">
                    <i class="bi bi-info-circle"></i>
                </div>

                <div class="student-card-body">
                    <h3>Information</h3>
                    <p class="student-card-text">
                        This dashboard shows your real FYP progress, academic stage, and the next action required in the official workflow.
                    </p>

                    <div class="student-link-list">
                        <a asp-controller="Fyp" asp-action="Index">Open Full FYP Workspace</a>
                        <a href="/templates/SRS%20Template.docx" download>Download Templates</a>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>
