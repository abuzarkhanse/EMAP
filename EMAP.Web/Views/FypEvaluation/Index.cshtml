@model IEnumerable<EMAP.Domain.Fyp.FypEvaluation>

@{
    ViewData["Title"] = "FYP Evaluations";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-1">FYP Evaluations</h3>
                <small class="text-muted">Schedule and manage evaluation events for student groups.</small>
            </div>
            <a asp-action="Create" class="btn btn-primary">Schedule Evaluation</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Group</th>
                            <th>Milestone</th>
                            <th>Schedule</th>
                            <th>Venue</th>
                            <th>Published</th>
                            <th>Committee Visible</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.StudentGroupId</td>
                                <td>@item.Milestone.Title</td>
                                <td>@(item.ScheduledAt?.ToString("dd MMM yyyy hh:mm tt") ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Venue) ? "-" : item.Venue)</td>
                                <td>@(item.IsPublishedToStudent ? "Yes" : "No")</td>
                                <td>@(item.ShowCommitteeToStudent ? "Yes" : "No")</td>
                                <td>@item.Status</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>