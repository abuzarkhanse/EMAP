@model IEnumerable<EMAP.Domain.Fyp.FypEvaluation>

@{
    ViewData["Title"] = "FYP Evaluations";
}

<div class="container py-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-1">FYP Evaluations</h3>
                <small class="text-muted">
                    Manage evaluation scheduling, publishing, venue, committee visibility, and student instructions.
                </small>
            </div>
            <a asp-action="Create" class="btn btn-primary">Create Evaluation Event</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Group</th>
                            <th>Evaluation</th>
                            <th>Schedule</th>
                            <th>Venue</th>
                            <th>Published</th>
                            <th>Committee Visible</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">#@item.StudentGroupId</div>
                                </td>

                                <td>
                                    <div class="fw-semibold">@item.Milestone.Title</div>
                                    <small class="text-muted">@item.Milestone.Stage</small>
                                </td>

                                <td>
                                    @(item.ScheduledAt?.ToString("dd MMM yyyy hh:mm tt") ?? "Not scheduled")
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.Venue) ? "-" : item.Venue)
                                </td>

                                <td>
                                    @if (item.IsPublishedToStudent)
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>

                                <td>
                                    @if (item.ShowCommitteeToStudent)
                                    {
                                        <span class="badge bg-info text-dark">Visible</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">Hidden</span>
                                    }
                                </td>

                                <td>
                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                </td>

                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        Manage
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>